# Copy this file to ".env" and fill in your key.

# ---- Provider: "groq" (free hosted, recommended) or "ollama" (local) ----
LLM_PROVIDER=groq

# ---- Groq (free key from https://console.groq.com) ----
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# ---- Ollama (local, offline). Run `ollama pull qwen2.5:7b` first. ----
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_URL=http://localhost:11434/api/chat

# ---- Judge model (scores V1 vs V2). Leave blank to reuse the primary. ----
# Tip: keep this on a 70B model for trustworthy scores even if a smaller
# model does the answering.
JUDGE_PROVIDER=groq
JUDGE_MODEL=

# ---- Knobs ----
TOP_K_EVIDENCE=6
TOP_K_LESSONS=3
