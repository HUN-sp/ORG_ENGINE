# Copy this file to ".env" and fill in a key. Pick ONE provider.

# ---- Active provider: openrouter | groq | ollama | mock ----
LLM_PROVIDER=openrouter
JUDGE_PROVIDER=openrouter

# ---- OpenRouter (free tier — https://openrouter.ai/keys) ----
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemma-4-31b-it:free
# Other free options (availability varies): meta-llama/llama-3.3-70b-instruct:free,
# nvidia/nemotron-3-super-120b-a12b:free, qwen/qwen3-next-80b-a3b-instruct:free

# ---- Groq (free key — https://console.groq.com) ----
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# ---- Ollama (local, offline; run `ollama pull qwen2.5:7b`) ----
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_URL=http://localhost:11434/api/chat

# ---- Judge model override ("" = use the provider's default model) ----
JUDGE_MODEL=

# ---- Knobs ----
TOP_K_EVIDENCE=6
TOP_K_LESSONS=3
